set company "CIC"
set designer "Student"

#### N16ADFP search path and link library 

set search_path " /usr/cad/process/ADFP/Executable_Package/Collaterals/IP/stdcell/N16ADFP_StdCell/NLDM/ \
                  /usr/cad/process/ADFP/Executable_Package/Collaterals/IP/stdio/N16ADFP_StdiIO/NLDM/ \
                  /usr/cad/process/ADFP/Executable_Package/Collaterals/IP/sram/N16ADFP_SRAM/NLDM/ \
                  $search_path"


set target_library   "N16ADFP_StdCellss0p72vm40c.db N16ADFP_StdCellff0p88v125c.db \
                      N16ADFP_StdIOss0p72v1p62v125c.db N16ADFP_StdIOff0p88v1p98vm40c.db \
                      N16ADFP_SRAM_ss0p72v0p72vm40c_100a.db N16ADFP_SRAM_ff0p88v0p88v125c_100a.db \
                     "


set link_library "* $target_library"
